package routes

import "github.com/mobiletoly/goldr/examples/full_feature/app/urls"

templ PageView() {
	<section>
		<h1>Goldr Example</h1>
		<p>Server-rendered pages, nested layouts, HTMX fragments, actions, and custom error views.</p>
		<p><a href={ urls.Users.Path() }>Open users</a></p>
	</section>
}
